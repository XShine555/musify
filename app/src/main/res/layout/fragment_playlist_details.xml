<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.playlist.PlaylistDetailsFragment"
    tools:paddingHorizontal="@dimen/screen_padding_vertical"
    tools:paddingVertical="@dimen/screen_padding_horizontal">

    <ImageButton
        android:id="@+id/go_back_button"
        android:layout_width="@dimen/icon_size_medium"
        android:layout_height="@dimen/icon_size_medium"
        android:background="@drawable/bg_go_back_button"
        android:contentDescription="@string/go_back_button_content_descriptor"
        android:scaleType="centerInside"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/playlist_image"
        android:layout_width="@dimen/image_size_large"
        android:layout_height="@dimen/image_size_large"
        android:layout_marginTop="@dimen/item_margin_medium"
        android:scaleType="centerCrop"
        app:layout_constraintEnd_toStartOf="@+id/playlist_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/go_back_button"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.Musify.ImageRounded"
        tools:src="@drawable/img_playlist_placeholder" />

    <TextView
        android:id="@+id/playlist_title"
        style="@style/TextAppearance.Musify.ExtraLarge"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/item_margin_medium"
        app:layout_constraintBottom_toBottomOf="@id/playlist_image"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/playlist_image"
        app:layout_constraintTop_toTopOf="@id/playlist_image"
        tools:text="Donde Quiero Estar" />

    <TextView
        android:id="@+id/playlist_summary"
        style="@style/TextAppearance.Musify.Small"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/item_margin_small"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/playlist_image"
        tools:text="Creada Por Ti • Contiene 1 Canción" />

    <LinearLayout
        android:id="@+id/action_buttons"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/item_margin_medium"
        android:orientation="horizontal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/playlist_summary">

        <ImageButton
            android:id="@+id/button_play"
            android:layout_width="@dimen/icon_size_medium"
            android:layout_height="@dimen/icon_size_medium"
            android:layout_marginEnd="@dimen/item_margin_medium"
            android:background="@drawable/ic_play_circle"
            android:contentDescription="Reproducir playlist" />

        <ImageButton
            android:id="@+id/button_shuffle"
            android:layout_width="@dimen/icon_size_medium"
            android:layout_height="@dimen/icon_size_medium"
            android:layout_marginEnd="@dimen/item_margin_medium"
            android:background="@drawable/ic_shuffle"
            android:contentDescription="Modo aleatorio" />

        <ImageButton
            android:id="@+id/button_share"
            android:layout_width="@dimen/icon_size_medium"
            android:layout_height="@dimen/icon_size_medium"
            android:background="@drawable/ic_share"
            android:contentDescription="Compartir playlist" />

    </LinearLayout>

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/manage_chip_group"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/item_margin_small"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/action_buttons">

        <com.google.android.material.chip.Chip
            android:id="@+id/sort_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ordenar" />

        <com.google.android.material.chip.Chip
            android:id="@+id/edit_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Editar" />

        <com.google.android.material.chip.Chip
            android:id="@+id/delete_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Borrar" />
    </com.google.android.material.chip.ChipGroup>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/tracks_recycler_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/item_margin_medium"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/manage_chip_group"
        tools:itemCount="1"
        tools:listitem="@layout/item_song" />

</androidx.constraintlayout.widget.ConstraintLayout>