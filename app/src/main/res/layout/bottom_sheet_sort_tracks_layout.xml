<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingHorizontal="@dimen/screen_padding_horizontal"
    android:paddingVertical="@dimen/screen_padding_vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/sort_by_title_button"
            style="@style/Widget.Musify.Button.Outlined"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/item_margin_medium"
            android:text="Sort by Title"
            android:textAppearance="@style/TextAppearance.Musify"
            app:iconGravity="textEnd"
            app:iconSize="@dimen/icon_size_small" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/sort_by_artist_button"
            style="@style/Widget.Musify.Button.Outlined"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/item_margin_medium"
            android:layout_marginEnd="@dimen/item_margin_medium"
            android:text="Sort by Artist"
            android:textAppearance="@style/TextAppearance.Musify"
            app:iconGravity="textEnd"
            app:iconSize="@dimen/icon_size_small" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/sort_by_duration_button"
            style="@style/Widget.Musify.Button.Outlined"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/item_margin_medium"
            android:layout_marginEnd="@dimen/item_margin_medium"
            android:text="Sort by Duration"
            android:textAppearance="@style/TextAppearance.Musify"
            app:iconGravity="textEnd"
            app:iconSize="@dimen/icon_size_small" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/sort_by_date_added_button"
            style="@style/Widget.Musify.Button.Outlined"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/item_margin_medium"
            android:layout_marginEnd="@dimen/item_margin_medium"
            android:text="Sort by Date Added"
            android:textAppearance="@style/TextAppearance.Musify"
            app:iconGravity="textEnd"
            app:iconSize="@dimen/icon_size_small" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>